// 3A Services - Full Prisma Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  CUSTOMER
  WORKER
  ADMIN
}

enum BookingStatus {
  PENDING
  ACCEPTED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DECLINED
}

enum PricingType {
  HOURLY
  FIXED
}

enum PlanType {
  FREE
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

// ─────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  passwordHash  String   @map("password_hash")
  role          Role     @default(CUSTOMER)
  phone         String?  // Hidden from public, internal use only
  avatarUrl     String?  @map("avatar_url")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  workerProfile   WorkerProfile?
  customerBookings Booking[]     @relation("CustomerBookings")
  workerBookings  Booking[]      @relation("WorkerBookings")
  reviewsGiven    Review[]       @relation("ReviewsGiven")
  reviewsReceived Review[]       @relation("ReviewsReceived")
  subscription    Subscription?
  sentMessages    Message[]      @relation("SentMessages")
  receivedMessages Message[]     @relation("ReceivedMessages")
  refreshTokens   RefreshToken[]
  notifications   Notification[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// WORKER PROFILES
// ─────────────────────────────────────────────

model WorkerProfile {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  profileImage    String?  @map("profile_image")
  bio             String?  @db.Text
  experienceYears Int      @default(0) @map("experience_years")
  location        String   @default("Mauritius")
  isVerified      Boolean  @default(false) @map("is_verified")
  isApproved      Boolean  @default(false) @map("is_approved")
  ratingAvg       Float    @default(0) @map("rating_avg")
  totalReviews    Int      @default(0) @map("total_reviews")
  totalBookings   Int      @default(0) @map("total_bookings")
  isAvailable     Boolean  @default(true) @map("is_available")
  isFeatured      Boolean  @default(false) @map("is_featured")
  responseTime    String?  @map("response_time") // e.g. "Usually within 1 hour"
  coverImageUrl   String?  @map("cover_image_url")
  tagline         String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workerServices  WorkerService[]
  availability    WorkerAvailability[]
  photos          WorkerPhoto[]

  @@map("worker_profiles")
}

model WorkerAvailability {
  id          String   @id @default(uuid())
  workerId    String   @map("worker_id")
  dayOfWeek   Int      @map("day_of_week") // 0=Sunday, 6=Saturday
  startTime   String   @map("start_time") // "08:00"
  endTime     String   @map("end_time")   // "17:00"
  isAvailable Boolean  @default(true) @map("is_available")

  worker WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@map("worker_availability")
}

model WorkerPhoto {
  id        String   @id @default(uuid())
  workerId  String   @map("worker_id")
  url       String
  caption   String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  worker WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@map("worker_photos")
}

// ─────────────────────────────────────────────
// SERVICES
// ─────────────────────────────────────────────

model Service {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  icon        String  // Lucide icon name or emoji
  description String? @db.Text
  imageUrl    String? @map("image_url")
  isActive    Boolean @default(true) @map("is_active")
  sortOrder   Int     @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  workerServices WorkerService[]
  bookings       Booking[]

  @@map("services")
}

model WorkerService {
  id          String      @id @default(uuid())
  workerId    String      @map("worker_id")
  serviceId   String      @map("service_id")
  price       Decimal     @db.Decimal(10, 2)
  pricingType PricingType @default(HOURLY) @map("pricing_type")
  minHours    Int?        @map("min_hours")
  description String?     @db.Text
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")

  // Relations
  worker  WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  service Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([workerId, serviceId])
  @@map("worker_services")
}

// ─────────────────────────────────────────────
// BOOKINGS
// ─────────────────────────────────────────────

model Booking {
  id           String        @id @default(uuid())
  customerId   String        @map("customer_id")
  workerId     String        @map("worker_id")
  serviceId    String        @map("service_id")
  date         DateTime
  timeSlot     String        @map("time_slot") // "09:00 - 11:00"
  address      String
  addressNotes String?       @map("address_notes") @db.Text
  notes        String?       @db.Text
  status       BookingStatus @default(PENDING)
  totalPrice   Decimal       @db.Decimal(10, 2) @map("total_price")
  platformFee  Decimal       @db.Decimal(10, 2) @map("platform_fee")
  workerEarning Decimal      @db.Decimal(10, 2) @map("worker_earning")
  isPaid       Boolean       @default(false) @map("is_paid")
  cancelReason String?       @map("cancel_reason") @db.Text
  declineReason String?      @map("decline_reason") @db.Text
  confirmedAt  DateTime?     @map("confirmed_at")
  completedAt  DateTime?     @map("completed_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  // Relations
  customer User    @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: Cascade)
  worker   User    @relation("WorkerBookings", fields: [workerId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id])
  review   Review?

  @@map("bookings")
}

// ─────────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────────

model Review {
  id         String   @id @default(uuid())
  bookingId  String   @unique @map("booking_id")
  customerId String   @map("customer_id")
  workerId   String   @map("worker_id")
  rating     Int      // 1-5
  comment    String?  @db.Text
  reply      String?  @db.Text // Worker's reply
  isVisible  Boolean  @default(true) @map("is_visible")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  booking  Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customer User    @relation("ReviewsGiven", fields: [customerId], references: [id])
  worker   User    @relation("ReviewsReceived", fields: [workerId], references: [id])

  @@map("reviews")
}

// ─────────────────────────────────────────────
// SUBSCRIPTIONS (PREMIUM)
// ─────────────────────────────────────────────

model Subscription {
  id         String             @id @default(uuid())
  userId     String             @unique @map("user_id")
  planType   PlanType           @default(FREE) @map("plan_type")
  status     SubscriptionStatus @default(ACTIVE)
  startDate  DateTime           @map("start_date")
  endDate    DateTime           @map("end_date")
  pricePaid  Decimal?           @db.Decimal(10, 2) @map("price_paid")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ─────────────────────────────────────────────
// MESSAGING
// ─────────────────────────────────────────────

model Message {
  id          String        @id @default(uuid())
  senderId    String        @map("sender_id")
  receiverId  String        @map("receiver_id")
  bookingId   String?       @map("booking_id")
  content     String        @db.Text
  status      MessageStatus @default(SENT)
  createdAt   DateTime      @default(now()) @map("created_at")

  sender   User @relation("SentMessages", fields: [senderId], references: [id])
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@map("messages")
}

// ─────────────────────────────────────────────
// SITE CONTENT (CMS)
// ─────────────────────────────────────────────

model SiteContent {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_content")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  body      String   @db.Text
  type      String   // booking_update, new_message, review, system
  isRead    Boolean  @default(false) @map("is_read")
  actionUrl String?  @map("action_url")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
